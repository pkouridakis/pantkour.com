---
import { siteConfig } from "../config";
---

<!-- DESKTOP sidebar -->
<aside class="hidden lg:block w-[260px] lg:sticky lg:top-10 flex-shrink-0">
  <div class="sidebar-card rounded-2xl p-6 flex flex-col items-center text-center">

    <div class="w-52 h-52 rounded-2xl overflow-hidden sidebar-icon-bg mb-5 border-2" style="border-color: var(--border)">
      <img src={siteConfig.avatar} alt={siteConfig.name} class="w-full h-full object-cover"
        onerror="this.style.display='none'; this.parentElement.innerHTML='<div style=\'width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:3rem;color:#666\'>👤</div>'" />
    </div>

    <h1 class="text-lg font-bold mb-2" style="color: var(--text)">{siteConfig.name}</h1>
    <span class="text-xs px-3 py-1.5 rounded-md mb-4 font-medium" style="background: var(--bg-icon); color: var(--text-muted)">
      {siteConfig.title.split("&")[0].trim()}
    </span>

    <div class="w-full sidebar-divider border-t mb-4"></div>

    <div class="w-full space-y-3 text-left">
      {siteConfig.social?.email && (
        <a href={`mailto:${siteConfig.social.email}`} class="flex items-start gap-3 group">
          <div class="w-9 h-9 rounded-lg sidebar-icon-bg flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" style="color: var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/><path d="M3 7l9 6 9-6"/>
            </svg>
          </div>
          <div>
            <p class="text-[11px] sidebar-label uppercase tracking-wider font-semibold">Email</p>
            <p class="text-xs sidebar-value truncate max-w-[150px]">{siteConfig.social.email}</p>
          </div>
        </a>
      )}
      {siteConfig.location && (
        <div class="flex items-start gap-3">
          <div class="w-9 h-9 rounded-lg sidebar-icon-bg flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" style="color: var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2a7 7 0 0 1 7 7c0 4.97-7 13-7 13S5 13.97 5 9a7 7 0 0 1 7-7z"/><circle cx="12" cy="9" r="2.5"/>
            </svg>
          </div>
          <div>
            <p class="text-[11px] sidebar-label uppercase tracking-wider font-semibold">Location</p>
            <p class="text-xs sidebar-value">{siteConfig.location}</p>
          </div>
        </div>
      )}
    </div>

    <div class="w-full sidebar-divider border-t my-4"></div>

    <div class="flex gap-3 justify-center">
      {siteConfig.social?.linkedin && (
        <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer"
           class="w-9 h-9 rounded-lg sidebar-social flex items-center justify-center" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M8 11v5"/><path d="M8 8v.01"/><path d="M12 16v-5"/><path d="M16 16v-3a2 2 0 1 0-4 0"/><path d="M3 7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4z"/>
          </svg>
        </a>
      )}
      {siteConfig.social?.github && (
        <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer"
           class="w-9 h-9 rounded-lg sidebar-social flex items-center justify-center" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2c2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2a4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0c-2.4-1.6-3.5-1.3-3.5-1.3a4.2 4.2 0 0 0-.1 3.2a4.6 4.6 0 0 0-1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6.6-.6 1.2-.5 2v3.5"/>
          </svg>
        </a>
      )}
      {siteConfig.social?.email && (
        <a href={`mailto:${siteConfig.social.email}`}
           class="w-9 h-9 rounded-lg sidebar-social flex items-center justify-center" aria-label="Email">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/><path d="M3 7l9 6 9-6"/>
          </svg>
        </a>
      )}
    </div>
  </div>
</aside>

<!-- MOBILE header (visible only on mobile) -->
<div class="lg:hidden sidebar-card rounded-2xl p-5 mb-4 flex items-center gap-5">
  <div class="w-24 h-24 rounded-2xl overflow-hidden sidebar-icon-bg flex-shrink-0 border-2" style="border-color: var(--border)">
    <img src={siteConfig.avatar} alt={siteConfig.name} class="w-full h-full object-cover"
      onerror="this.style.display='none'; this.parentElement.innerHTML='<div style=\'width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:2.5rem\'>👤</div>'" />
  </div>
  <div class="flex-1 min-w-0">
    <h1 class="text-lg font-bold" style="color: var(--text)">{siteConfig.name}</h1>
    <p class="text-sm mt-1 font-medium" style="color: var(--text-muted)">{siteConfig.title.split("&")[0].trim()}</p>
    <p class="text-xs mt-1 flex items-center gap-1" style="color: var(--text-dim)">
      <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2a7 7 0 0 1 7 7c0 4.97-7 13-7 13S5 13.97 5 9a7 7 0 0 1 7-7z"/><circle cx="12" cy="9" r="2.5"/>
      </svg>
      {siteConfig.location}
    </p>
    <div class="flex gap-2 mt-3">
      {siteConfig.social?.linkedin && (
        <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer"
           class="w-9 h-9 rounded-lg sidebar-social flex items-center justify-center" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M8 11v5"/><path d="M8 8v.01"/><path d="M12 16v-5"/><path d="M16 16v-3a2 2 0 1 0-4 0"/><path d="M3 7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4z"/>
          </svg>
        </a>
      )}
      {siteConfig.social?.github && (
        <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer"
           class="w-9 h-9 rounded-lg sidebar-social flex items-center justify-center" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2c2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2a4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0c-2.4-1.6-3.5-1.3-3.5-1.3a4.2 4.2 0 0 0-.1 3.2a4.6 4.6 0 0 0-1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6.6-.6 1.2-.5 2v3.5"/>
          </svg>
        </a>
      )}
    </div>
  </div>
</div>
